# Copy to .env and adjust. Never commit the real .env.
DB_SERVER=localhost,1433
DB_NAME=CreditRisk
DB_USER=sa
DB_PASSWORD=Your_strong_Pass123
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_TRUST_CERT=yes

MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT=credit-risk

MODEL_DIR=models
MODEL_NAME=credit_risk_model.joblib

# Decision policy (probability of default)
APPROVE_BELOW=0.15
DECLINE_ABOVE=0.45
